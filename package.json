{
	"name": "shelleport",
	"version": "0.1.0",
	"homepage": "https://github.com/obviyus/shelleport#readme",
	"bugs": {
		"url": "https://github.com/obviyus/shelleport/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/obviyus/shelleport.git"
	},
	"bin": {
		"shelleport": "./bin/shelleport.js"
	},
	"files": [
		"bin",
		"scripts",
		"README.md"
	],
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run ./scripts/build.ts",
		"compile": "bun run ./scripts/package.ts local",
		"dev": "bun --watch ./scripts/dev.ts",
		"start": "bun run build && bun run server.ts serve",
		"doctor": "bun run server.ts doctor",
		"install-service": "bun run server.ts install-service",
		"postinstall": "node ./scripts/postinstall.js",
		"release:build": "bun run ./scripts/package.ts release",
		"format": "oxfmt --check .",
		"format:write": "oxfmt --write .",
		"lint": "oxlint --type-aware app server.ts scripts bin",
		"lint:fix": "oxlint --type-aware app server.ts scripts bin --fix",
		"smoke": "bun run ./scripts/smoke.ts",
		"test:claude": "bun test ./app/server/api.claude.integration.ts --timeout 120000",
		"typecheck": "bunx tsgo --noEmit -p tsconfig.json",
		"test": "bun test"
	},
	"dependencies": {
		"@pierre/diffs": "^1.1.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.7.0",
		"motion": "^12.38.0",
		"p-limit": "^7.3.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260325.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"oxlint-tsgolint": "^0.17.4",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2"
	}
}
