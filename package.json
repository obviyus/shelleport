{
	"name": "shelleport",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bunx --bun react-router build",
		"compile": "bun build --compile ./server.ts --outfile dist/shelleport",
		"dev": "bunx --bun react-router dev",
		"start": "bun run server.ts serve",
		"doctor": "bun run server.ts doctor",
		"install-service": "bun run server.ts install-service",
		"format": "oxfmt --check .",
		"format:write": "oxfmt --write .",
		"lint": "oxlint --type-aware app server.ts react-router.config.ts vite.config.ts",
		"lint:fix": "oxlint --type-aware app server.ts react-router.config.ts vite.config.ts --fix",
		"test:claude": "bun test ./app/server/api.claude.integration.ts --timeout 120000",
		"typecheck": "react-router typegen && tsgo --noEmit -p tsconfig.json",
		"test": "bun test"
	},
	"dependencies": {
		"@pierre/diffs": "^1.1.5",
		"@react-router/node": "^7.13.2",
		"@react-router/serve": "^7.13.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"isbot": "^5.1.36",
		"lucide-react": "^1.7.0",
		"motion": "^12.38.0",
		"p-limit": "^7.3.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"react-router": "^7.13.2",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@react-router/dev": "^7.13.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260325.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"oxlint-tsgolint": "^0.17.4",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "npm:rolldown-vite@7.3.1",
		"vite-tsconfig-paths": "^6.1.1"
	}
}
