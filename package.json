{
	"name": "shelleport",
	"version": "0.0.24",
	"description": "Browser control plane for coding agent sessions",
	"keywords": [
		"agent",
		"bun",
		"claude",
		"cli",
		"remote-control",
		"sse"
	],
	"homepage": "https://github.com/obviyus/shelleport#readme",
	"bugs": {
		"url": "https://github.com/obviyus/shelleport/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/obviyus/shelleport.git"
	},
	"bin": {
		"shelleport": "bin/shelleport.js"
	},
	"files": [
		"bin",
		"scripts/npm-runtime.js",
		"scripts/postinstall.js",
		"README.md",
		"LICENSE"
	],
	"os": [
		"darwin",
		"linux"
	],
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run ./scripts/build.ts",
		"compile": "bun run ./scripts/package.ts local",
		"dev": "bun run server.ts serve",
		"start": "bun run build && cd ./build/server && NODE_ENV=production bun ./server.js serve",
		"start:source": "NODE_ENV=production bun run server.ts serve",
		"doctor": "bun run server.ts doctor",
		"install-service": "bun run server.ts install-service",
		"postinstall": "node ./scripts/postinstall.js",
		"release:build": "bun run ./scripts/package.ts release",
		"format": "oxfmt --check .",
		"format:write": "oxfmt --write .",
		"lint": "oxlint --type-aware src server.ts scripts bin",
		"lint:fix": "oxlint --type-aware src server.ts scripts bin --fix",
		"smoke": "bun run ./scripts/smoke.ts",
		"test:claude": "bun test ./src/server/api.claude.integration.ts --max-concurrency 1 --timeout 120000",
		"typecheck": "bunx tsgo --noEmit -p tsconfig.json",
		"test": "bun test --max-concurrency 1",
		"check": "bun run format && bun run lint && bun run typecheck"
	},
	"dependencies": {
		"@pierre/diffs": "^1.1.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.7.0",
		"motion": "^12.38.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260325.1",
		"bun-plugin-tailwind": "^0.1.2",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"oxlint-tsgolint": "^0.17.4",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2"
	},
	"engines": {
		"node": ">=18"
	}
}
